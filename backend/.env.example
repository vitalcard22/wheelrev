# Copy this file to .env and fill in real values.

PORT=4000

# Local Postgres example:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/wheelrev

# Hosted Postgres (Neon, Fly.io Postgres, etc.) will give you a connection
# string that looks like this:
# DATABASE_URL=postgres://user:password@host:5432/dbname
#
# If DATABASE_URL is left unset, the backend automatically falls back to
# reading car data from src/data/cars.json instead — the site still works,
# it just won't support adding/editing/deleting cars.

# Required to use the admin panel (frontend/admin.html). Pick any password —
# this is a basic shared-secret gate, not full authentication. Do not reuse
# a real account password here.
ADMIN_TOKEN=change-me-to-something-only-you-know
